# Copy to `.env` and fill in. Never commit `.env`.

# Required — Google AI Studio key for Gemini.
# https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional — Backboard API key.
# https://app.backboard.io/  (sign in -> Settings -> API Keys)
# When set, BackboardClient writes to the real Backboard API.
# When blank, it falls back to localStorage so the app still runs.
VITE_BACKBOARD_API_KEY=
