# Copy to `.env` and fill in. Never commit `.env`.

# Required — Google AI Studio key for Gemini.
# https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Reserved — once the Backboard SDK lands (see BLOCKER.md), put the key here.
# Today the app uses a localStorage-backed stand-in and this variable is ignored.
VITE_BACKBOARD_API_KEY=
